# Port the Next.js web server listens on (Next dev defaults to 3000)
PORT=3000

# Backend API base URL. Resolved at RUNTIME by the /api proxy
# (app/api/[...path]/route.js) — not baked into the build — so the same
# image works in any environment. docker-compose sets this to http://server:3001.
API_BASE_URL=http://localhost:3001

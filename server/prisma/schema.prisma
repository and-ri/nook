generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum BillingCycle {
    YEARLY
    MONTHLY
    WEEKLY
    DAILY
}

enum SubscriptionStatus {
    ACTIVE
    CANCELLED
    PAUSED
    TRIAL
}

enum TeamRole {
    OWNER
    MEMBER
}

model User {
    id                String          @id @default(uuid())
    email             String          @unique
    passwordHash      String
    name              String
    preferredCurrency String          @default("USD")

    // Entities this user created (ownership is by team; this is "created by")
    subscriptions     Subscription[]
    categories        Category[]
    paymentMethods    PaymentMethod[]

    // Teams
    memberships  TeamMember[]
    activeTeamId String?
    activeTeam   Team?       @relation("ActiveTeam", fields: [activeTeamId], references: [id], onDelete: SetNull)
    reminderLogs ReminderLog[]

    // IANA timezone (e.g. "Europe/Kyiv"); reminders are delivered 09:00–12:00
    // local. Null until a client reports it; the scheduler falls back to UTC.
    timezone String?

    // Payment reminder preferences. notifyEnabled / pushEnabled are the channel
    // masters; the three toggles below decide WHAT is sent (and apply to both
    // channels).
    notifyEnabled    Boolean @default(false)
    notifyDaysBefore Int     @default(3)
    remindBefore     Boolean @default(true)  // N days before a payment
    remindOnDueDate  Boolean @default(false) // on the due date
    weeklySummary    Boolean @default(false) // Monday "this week" summary
    lastWeeklySummaryAt DateTime?

    // Set when the user requests account deletion. The scheduler hard-deletes the
    // account a grace period later; clearing it (restore) cancels the deletion.
    deletionRequestedAt DateTime?

    // Push notifications (Expo)
    pushEnabled   Boolean        @default(false)
    pushTokens    PushToken[]
    notifications Notification[]

    // Password reset
    resetTokenHash      String?
    resetTokenExpiresAt DateTime?

    createdAt         DateTime        @default(now())
    updatedAt         DateTime        @updatedAt
}

model Team {
    id             String           @id @default(uuid())
    name           String
    members        TeamMember[]
    invitations    TeamInvitation[]
    subscriptions  Subscription[]
    categories     Category[]
    paymentMethods PaymentMethod[]
    activeForUsers User[]           @relation("ActiveTeam")
    createdAt      DateTime         @default(now())
    updatedAt      DateTime         @updatedAt
}

model TeamMember {
    id        String   @id @default(uuid())
    teamId    String
    team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    role      TeamRole @default(MEMBER)
    createdAt DateTime @default(now())

    @@unique([teamId, userId])
}

model TeamInvitation {
    id          String   @id @default(uuid())
    teamId      String
    team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
    email       String
    role        TeamRole @default(MEMBER)
    tokenHash   String   @unique
    expiresAt   DateTime
    invitedById String?
    createdAt   DateTime @default(now())

    @@index([email])
    @@index([teamId])
}

model PaymentMethod {
    id            String         @id @default(uuid())
    teamId        String
    team          Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
    userId        String?
    user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
    name          String
    type          String         @default("card")
    logoUrl       String?
    subscriptions Subscription[]
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt

    @@index([teamId])
}

model Subscription {
    id              String            @id @default(uuid())
    teamId          String
    team            Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
    userId          String?
    user            User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
    name            String
    url             String?
    logoUrl         String?
    categories      Category[]
    paymentMethodId String?
    paymentMethod   PaymentMethod?    @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
    amount          Float
    currency        String
    billingCycle    BillingCycle
    status          SubscriptionStatus
    startDate       DateTime?
    nextBillingDate DateTime?
    cancelledAt     DateTime?
    notes           String?
    reminderLogs    ReminderLog[]
    createdAt       DateTime          @default(now())
    updatedAt       DateTime          @updatedAt

    @@index([teamId])
}

// One row per (user, subscription, billing occurrence, kind) reminder sent, so
// each team member who enabled reminders is notified exactly once per charge per
// kind — "BEFORE" (N days ahead) and "DUE" (on the day) are deduped separately.
model ReminderLog {
    id             String       @id @default(uuid())
    userId         String
    user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
    subscriptionId String
    subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
    billingDate    DateTime
    kind           String       @default("BEFORE")
    createdAt      DateTime     @default(now())

    @@unique([userId, subscriptionId, billingDate, kind])
    @@index([subscriptionId])
}

model Category {
    id            String         @id @default(uuid())
    name          String
    subscriptions Subscription[]
    teamId        String
    team          Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
    userId        String?
    user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt

    @@index([teamId])
}

// One Expo push token per device. A user may have several.
model PushToken {
    id        String   @id @default(uuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    token     String   @unique
    platform  String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([userId])
}

// In-app notification center entries. Written whenever a reminder is dispatched.
model Notification {
    id        String    @id @default(uuid())
    userId    String
    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    title     String
    body      String
    type      String    @default("reminder")
    data      Json?
    readAt    DateTime?
    createdAt DateTime  @default(now())

    @@index([userId, createdAt])
}
